TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Optional: override the model (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Optional: comma-separated list of allowed Telegram user IDs (whitelist)
# Leave empty to block all users
# ALLOWED_USER_IDS=12345678,98765432

# Optional: path to a Netscape-format cookies file for yt-dlp
YTDLP_COOKIES_FILE=cookies.txt